{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SHIELD RAG Eval Item",
  "type": "object",
  "required": ["id", "domain", "query", "category_ids", "bm25_keywords", "gold_articles"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^C1-Q[0-9]{2}$"
    },
    "domain": {
      "type": "string",
      "enum": [
        "real_estate_sale",
        "real_estate_lease",
        "real_estate_security",
        "real_estate_rights",
        "family_divorce",
        "family_parental",
        "inheritance",
        "inheritance_reserve",
        "debt_guaranty",
        "debt_prescription",
        "contract_general",
        "tort",
        "misc"
      ]
    },
    "query": {"type": "string", "minLength": 5},
    "category_ids": {
      "oneOf": [
        {"type": "null"},
        {"type": "array", "items": {"type": "string"}}
      ]
    },
    "bm25_keywords": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "gold_articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["law_id", "article_no"],
        "properties": {
          "law_id": {"type": "string"},
          "article_no": {"type": "string"}
        }
      },
      "minItems": 1,
      "maxItems": 3
    },
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
